# App
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000

# Neon Postgres
# DATABASE_URL = pooled connection string (for the running app)
# DIRECT_URL   = direct connection string (for prisma migrate)
# Get both from your Neon project dashboard -> Connection Details
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/rentnest?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/rentnest?sslmode=require"

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Cloudinary (property images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SSLCommerz (sandbox)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_LIVE=false
