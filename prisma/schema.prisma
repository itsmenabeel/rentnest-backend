generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Neon pooled connection (via pgbouncer) — used at runtime
  directUrl = env("DIRECT_URL")   // Neon direct connection — used for migrations
}

enum Role {
  TENANT
  LANDLORD
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum RentalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentProvider {
  SSLCOMMERZ
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  phone     String?
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  properties     Property[]      @relation("LandlordProperties")
  rentalRequests RentalRequest[] @relation("TenantRequests")
  reviews        Review[]

  @@map("users")
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  properties Property[]

  @@map("categories")
}

model Property {
  id          String   @id @default(uuid())
  title       String
  description String
  location    String
  price       Decimal  @db.Decimal(10, 2)
  amenities   String[]
  images      String[] // Cloudinary secure_urls
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  landlordId String
  landlord   User   @relation("LandlordProperties", fields: [landlordId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  rentalRequests RentalRequest[]
  reviews        Review[]

  @@index([location])
  @@index([price])
  @@map("properties")
}

model RentalRequest {
  id         String              @id @default(uuid())
  status     RentalRequestStatus @default(PENDING)
  moveInDate DateTime?
  message    String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  tenantId String
  tenant   User   @relation("TenantRequests", fields: [tenantId], references: [id])

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  payment Payment?
  review  Review?

  @@map("rental_requests")
}

model Payment {
  id            String          @id @default(uuid())
  transactionId String          @unique
  amount        Decimal         @db.Decimal(10, 2)
  provider      PaymentProvider @default(SSLCOMMERZ)
  status        PaymentStatus   @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  rentalRequestId String        @unique
  rentalRequest   RentalRequest @relation(fields: [rentalRequestId], references: [id])

  @@map("payments")
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  tenantId String
  tenant   User   @relation(fields: [tenantId], references: [id])

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  rentalRequestId String        @unique
  rentalRequest   RentalRequest @relation(fields: [rentalRequestId], references: [id])

  @@map("reviews")
}
